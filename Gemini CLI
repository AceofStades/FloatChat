                                <Alert
                                    variant={
                                        status.type === "error"
                                            ? "destructive"
                                            : "default"
                                    }
                                >
                                    {status.type === "success" ? (
                                        <CheckCircle className="h-4 w-4" />
                                    ) : (
                                        <AlertTriangle className="h-4 w-4" />
                                    )}
                                    <AlertDescription>
                                        {status.message}
                                    </AlertDescription>
