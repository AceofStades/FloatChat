    """Generates an interactive Plotly chart as HTML."""
    if df.empty:
        return "<h3>No data available for charting.</h3>"

    cols = df.columns.tolist()

    # Try to find logical x and y axes
    x_col = None
    y_col = None

    # Common time/sequence columns
